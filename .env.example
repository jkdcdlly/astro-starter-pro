# Cloudflare 配置
# 在 Cloudflare Pages 构建时自动设置，本地开发需要手动配置

# Cloudflare 账户 ID
CLOUDFLARE_ACCOUNT_ID=你的账户 ID

# Cloudflare API Token（需要 D1 读取权限）
# 创建方法：Cloudflare Dashboard -> My Profile -> API Tokens -> Create Token
# 权限：D1 -> Edit
CLOUDFLARE_API_TOKEN=你的 API Token

# 网站 URL（可选）
SITE_URL=https://war3maps.net/
