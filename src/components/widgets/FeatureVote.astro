---
import { Icon } from "astro-icon/components";
import Headline from "@/components/ui/Headline.astro";
import { useTranslations, getLangFromUrl } from "@/i18n";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// 功能投票数据
const features = [
  { id: 1, votes: 120 },
  { id: 2, votes: 98 },
  { id: 3, votes: 85 },
  { id: 4, votes: 76 },
  { id: 5, votes: 65 },
  { id: 6, votes: 54 },
  { id: 7, votes: 43 },
  { id: 8, votes: 32 },
  { id: 9, votes: 21 },
  { id: 10, votes: 10 },
];

// 按投票数排序
const sortedFeatures = [...features].sort((a, b) => b.votes - a.votes);
---

<section class="py-16">
  <div class="container mx-auto px-4">
    <div class="max-w-7xl mx-auto">
      <Headline
        title={t('widgets.featureVote.title')}
        
        tagline={t('widgets.featureVote.tagline')}
        classes={{
            container: "max-w-3xl mx-auto text-center",
        }}
    />
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {sortedFeatures.map((feature) => (
          <div class="bg-card border border-border rounded-lg p-6 shadow-sm hover:shadow-md transition-shadow" data-id={feature.id}>
            <div class="flex justify-between items-center mb-4">
              <h3 class="text-lg font-medium">{t('widgets.featureVote.features')[feature.id - 1]}</h3>
              <span class="bg-primary/10 text-primary px-3 py-1 rounded-full text-sm font-medium">
                {feature.votes} {t('widgets.featureVote.votes')}
              </span>
            </div>
            <button class="w-full flex items-center justify-center gap-2 px-4 py-2 bg-background border border-border rounded-md hover:bg-muted transition-colors">
              <Icon name="lucide:thumbs-up" class="w-4 h-4" />
              {t('widgets.featureVote.vote')}
            </button>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>