---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { siteConfig } from '../../../../config/site';
import { useTranslations, getLangFromUrl, ui, defaultLang } from "@/i18n";
import { dbService } from '../../../../services/database';

// 检查登录状态
const adminSession = Astro.cookies.get("admin_session")?.value;
const isLoggedIn = !!adminSession;

const db = (Astro.locals as any).runtime.env.DB;

// Export getStaticPaths function
export function getStaticPaths() {
  // Filter out default language (handled by root pages)
  const languages = Object.keys(ui).filter(lang => lang !== defaultLang);
  
  // Generate paths for each language (dynamic pages will be generated on the fly)
  return languages.map(lang => ({
    params: { lang, id: '1', mapname: 'map' },
    props: { lang },
  }));
}

interface Props {
    lang: string;
    id: string;
    mapname: string;
}
const params = Astro.params;
const mapId = params.id;
const mapName = params.mapname;

const lang = getLangFromUrl(Astro.url);

// 尝试获取缓存
const cacheKey = new URL(Astro.request.url);
let cache: Cache | null = null;

try {
  if (typeof caches !== 'undefined') {
    cache = await caches.open('astro-cache');
  }
} catch (e) {
  console.log('Cache not available');
}

// 查询地图详情数据
let mapData: any = null;

// 检查缓存中是否有数据
if (cache) {
  try {
    const cachedResponse = await cache.match(cacheKey);
    if (cachedResponse) {
      mapData = await cachedResponse.json();
    }
  } catch (e) {
    console.log('Cache read failed, fetching fresh data');
  }
}

// 如果缓存中没有数据或缓存不可用，从数据库获取
if (!mapData) {
  try {
    const sql = 'SELECT * FROM wc3_maps_complete WHERE id = ?';
    mapData = await dbService.executeFirst<any>(db,sql, [parseInt(mapId)]);
    
    // 缓存结果（如果缓存可用）
    if (cache && mapData) {
      try {
        const response = new Response(JSON.stringify(mapData), {
          headers: {
            'Cache-Control': 'public, max-age=300, s-maxage=300',
          }
        });
        await cache.put(cacheKey, response);
      } catch (e) {
        console.log('Cache write failed');
      }
    }
  } catch (error) {
    console.error('Error fetching map data:', error);
  }
}

// 如果还是没有数据，提供调试信息
if (!mapData) {
  console.log('No map data found - db available:', !!db);
}

// Slug 生成函数
function generateSlug(text: string): string {
  return text
    .toLowerCase()
    .replace(/[^\p{L}\p{N}\s-]/gu, '')  // 移除非字母、非数字、非空格、非连字符的字符（支持 Unicode）
    .replace(/\s+/g, '-')      // 空格替换为连字符
    .replace(/-+/g, '-')       // 多个连字符替换为单个
    .trim();
}

// 设置响应头缓存
Astro.response.headers.set('Cache-Control', 'public, max-age=300, s-maxage=300');

// 如果没有找到地图数据，返回404
if (!mapData) {
  return Astro.redirect('/404');
}

// 获取作者的其他地图
let authorMaps: any[] = [];
if (mapData.author) {
  try {
    const sql = 'SELECT id, name2, author, downloads FROM wc3_maps_complete WHERE author = ? AND id != ? ORDER BY downloads DESC LIMIT 10';
    authorMaps = await dbService.execute<any>(db, sql, [mapData.author, parseInt(mapId)]);
  } catch (error) {
    console.error('Error fetching author maps:', error);
  }
}
const shouldNoindex = mapData.tags.length === 0;
const map_title = mapData.name2 + " | " + "warcraft 3 maps downloads";
---

<BaseLayout title={map_title} lang={lang} noindex={shouldNoindex}>
  <section class="py-12">
    <div class="container mx-auto px-4">
      <!-- Header -->
      <div class="text-center mb-12">
        <h1 class="text-3xl font-bold mb-4">{mapData.name2}</h1>
        <p class="text-muted-foreground">by {mapData.author ? (
          <a href={`/${lang}/author/${generateSlug(mapData.author)}`} class="text-primary hover:underline">{mapData.author}</a>
        ) : 'Unknown'}</p>
        {isLoggedIn && (
          <button
            id="edit-map-btn"
            data-lang={lang}
            class="mt-4 px-6 py-2 bg-primary text-primary-foreground rounded-md hover:bg-primary/90 transition-colors"
          >
            编辑地图
          </button>
        )}
      </div>

      <!-- Main Content -->
      <div class="flex flex-col lg:flex-row gap-8">
        <!-- Left Column - Map Info -->
        <div class="w-full lg:w-1/3">
          <!-- Map Preview -->
          <div class="mb-6">
            <img 
              src={`https://wc3maps.com/static/maps/${mapData.id}/archive/war3mapMap.jpg`} 
              alt={mapData.name2} 
              class="w-full rounded-lg shadow-md"
              onerror="this.src='https://via.placeholder.com/400x300?text=No+Preview';"
            />
          </div>

          <!-- Action Buttons -->
          <div class="flex gap-4 mb-6">
            <a 
              href={`https://wc3maps.com/api/download/${mapData.id}`} 
              target="_blank"
              rel="nofollow noopener noreferrer"
              class="flex-1 px-4 py-2 bg-primary text-primary-foreground rounded-md hover:bg-primary/90 transition-colors"
            >
              Download
            </a>
            <a 
              href={`https://wc3maps.com/map/${mapData.id}`} 
              target="_blank"
              rel="nofollow noopener noreferrer"
              class="px-4 py-2 border border-border rounded-md hover:bg-muted transition-colors"
            >
            Download on WC3Maps
            </a>
          </div>

          <!-- Map Details -->
          <div class="bg-card border border-border rounded-lg p-4 mb-6">
            <h3 class="font-semibold mb-4">Map Details</h3>
            
            <div class="grid grid-cols-2 gap-4">
              <div>
                <p class="text-sm text-muted-foreground">Status</p>
                <p class="font-medium">{mapData.parsed ? 'Parsed' : 'Not Parsed'}</p>
              </div>
              <div>
                <p class="text-sm text-muted-foreground">Game Version</p>
                <p class="font-medium">{mapData.build || 'Unknown'}</p>
              </div>
              <div>
                <p class="text-sm text-muted-foreground">Version</p>
                <p class="font-medium">{mapData.format_version || 'Unknown'}</p>
              </div>
              <div>
                <p class="text-sm text-muted-foreground">Script</p>
                <p class="font-medium">{mapData.script === 1 ? 'Lua' : 'JASS'}</p>
              </div>
              <div>
                <p class="text-sm text-muted-foreground">Size</p>
                <p class="font-medium">{mapData.size ? `${(mapData.size / 1024 / 1024).toFixed(2)} MB` : 'Unknown'}</p>
              </div>
              <div>
                <p class="text-sm text-muted-foreground">Saves</p>
                <p class="font-medium">{mapData.saves || 0}</p>
              </div>
            </div>
          </div>

          <!-- Statistics -->
          <div class="bg-card border border-border rounded-lg p-4">
            <h3 class="font-semibold mb-4">Statistics</h3>
            
            <div class="space-y-4">
              <div>
                <div class="flex justify-between mb-1">
                  <p class="text-sm text-muted-foreground">Downloads</p>
                  <p class="font-medium">{mapData.downloads || 0}</p>
                </div>
                <div class="w-full bg-muted rounded-full h-2">
                  <div class="bg-primary h-2 rounded-full" style="width: 70%"></div>
                </div>
              </div>
              
              <div>
                <div class="flex justify-between mb-1">
                  <p class="text-sm text-muted-foreground">Hosted Total</p>
                  <p class="font-medium">{mapData.hosted_total || 0}</p>
                </div>
                <div class="w-full bg-muted rounded-full h-2">
                  <div class="bg-primary h-2 rounded-full" style="width: 50%"></div>
                </div>
              </div>
              
              <div>
                <div class="flex justify-between mb-1">
                  <p class="text-sm text-muted-foreground">Hosted This Month</p>
                  <p class="font-medium">{mapData.hosted_month || 0}</p>
                </div>
                <div class="w-full bg-muted rounded-full h-2">
                  <div class="bg-primary h-2 rounded-full" style="width: 30%"></div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Right Column - Description -->
        <div class="w-full lg:w-2/3">
          <!-- Description -->
          <div class="bg-card border border-border rounded-lg p-6 mb-6">
            <h3 class="font-semibold mb-4">Description</h3>
            <div class="prose max-w-none">
              {mapData.description ? (
                <div set:html={mapData.description.replace(/\n/g, '<br>')} />
              ) : (
                <p>No description available</p>
              )}
            </div>
          </div>

          <!-- Map Information -->
          <div class="bg-card border border-border rounded-lg p-6 mb-6">
            <h3 class="font-semibold mb-4">Map Information</h3>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <h4 class="font-medium mb-2">Basic Info</h4>
                <ul class="space-y-2">
                  <li class="flex justify-between">
                    <span class="text-muted-foreground">Author:</span>
                    <span>
                      {mapData.author ? (
                        <a href={`/${lang}/author/${generateSlug(mapData.author)}`} class="text-primary hover:underline">
                          {mapData.author}
                        </a>
                      ) : 'Unknown'}
                    </span>
                  </li>
                  <li class="flex justify-between">
                    <span class="text-muted-foreground">Players:</span>
                    <span>{mapData.player_count || 1}</span>
                  </li>
                  <li class="flex justify-between">
                    <span class="text-muted-foreground">Tileset:</span>
                    <span>{mapData.tileset || 'Unknown'}</span>
                  </li>
                  <li class="flex justify-between">
                    <span class="text-muted-foreground">Size:</span>
                    <span>{mapData.width}x{mapData.height} ({mapData.playable_width}x{mapData.playable_height} playable)</span>
                  </li>
                </ul>
              </div>
              
              <div>
                <h4 class="font-medium mb-2">Technical</h4>
                <ul class="space-y-2">
                  <li class="flex justify-between">
                    <span class="text-muted-foreground">Graphics:</span>
                    <span>{mapData.graphics === 2 ? 'HD' : mapData.graphics === 1 ? 'SD' : 'SD & HD'}</span>
                  </li>
                  <li class="flex justify-between">
                    <span class="text-muted-foreground">Triggers:</span>
                    <span>{mapData.has_triggers ? 'Yes' : 'No'}</span>
                  </li>
                  <li class="flex justify-between">
                    <span class="text-muted-foreground">Cheats:</span>
                    <span>{mapData.cheats ? 'Allowed' : 'Not Allowed'}</span>
                  </li>
                  <li class="flex justify-between">
                    <span class="text-muted-foreground">Team Count:</span>
                    <span>{mapData.team_count || 1}</span>
                  </li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Tags -->
          {mapData.tags && (
            <div class="bg-card border border-border rounded-lg p-6 mb-6">
              <h3 class="font-semibold mb-4">Tags</h3>
              <div class="flex flex-wrap gap-2">
                {mapData.tags.split(',').map((tag: string) => (
                  <span class="px-3 py-1 bg-muted text-muted-foreground rounded-full text-sm">
                    {tag.trim()}
                  </span>
                ))}
              </div>
            </div>
          )}

          <!-- Author's Other Maps -->
          {authorMaps.length > 0 && (
            <div class="bg-card border border-border rounded-lg p-6">
              <h3 class="font-semibold mb-4">Other Maps by {mapData.author}</h3>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                {authorMaps.map((map) => (
                  <a 
                    href={`/${lang}/map/${map.id}/${map.name2.toLowerCase().replace(/\s+/g, '-')}`}
                    class="flex items-center gap-3 p-3 bg-muted/50 rounded-md hover:bg-muted transition-colors"
                  >
                    
                    <div class="flex-1">
                      <h4 class="font-medium text-sm">{map.name2}</h4>
                      <p class="text-xs text-muted-foreground">{map.downloads} downloads</p>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          )}
        </div>
      </div>
    </div>
  </section>

  {isLoggedIn && (
    <>
      <!-- 编辑表单模态框 -->
      <div id="edit-modal" class="hidden fixed inset-0 z-50 overflow-y-auto ">
        <div class="flex min-h-screen items-center justify-center p-4">
          <!-- 背景遮罩 -->
          <div class="fixed inset-0 bg-black/50" id="modal-backdrop"></div>
          
          <!-- 模态框内容 -->
          <div class="relative z-10 w-full max-w-4xl rounded-lg bg-background p-6 shadow-lg">
            <div class="mb-6 flex items-center justify-between">
              <h2 class="text-2xl font-bold">编辑地图信息</h2>
              <button
                id="close-modal-btn"
                class="text-muted-foreground hover:text-foreground"
              >
                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
              </button>
            </div>

            <form id="edit-map-form" class="space-y-6">
              <input type="hidden" name="mapId" value={mapId} />
              <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div>
                  <label class="block text-sm font-medium mb-2">地图名称</label>
                  <input
                    type="text"
                    name="name2"
                    value={mapData.name2}
                    class="w-full rounded-md border border-border bg-input px-3 py-2 text-foreground focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/50"
                    required
                  />
                </div>

                <div>
                  <label class="block text-sm font-medium mb-2">作者</label>
                  <input
                    type="text"
                    name="author"
                    value={mapData.author || ''}
                    class="w-full rounded-md border border-border bg-input px-3 py-2 text-foreground focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/50"
                  />
                </div>
                 <div>
                  <label class="block text-sm font-medium mb-2">游戏版本</label>
                  <input
                    type="text"
                    name="build"
                    value={mapData.build || ''}
                    class="w-full rounded-md border border-border bg-input px-3 py-2 text-foreground focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/50"
                  />
                </div>
                 <div class="md:col-span-3">
                  <label class="block text-sm font-medium mb-2">标签</label>
                  <input
                    type="text"
                    name="tags"
                    value={mapData.tags || ''}
                    class="w-full rounded-md border border-border bg-input px-3 py-2 text-foreground focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/50"
                    placeholder="用逗号分隔"
                  />
                </div>

                <div class="md:col-span-3">
                  <label class="block text-sm font-medium mb-2">描述</label>
                  <textarea
                    name="description"
                    rows="4"
                    class="w-full rounded-md border border-border bg-input px-3 py-2 text-foreground focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/50"
                  >{mapData.description || ''}</textarea>
                </div>

               

                <div>
                  <label class="block text-sm font-medium mb-2">格式版本</label>
                  <input
                    type="text"
                    name="format_version"
                    value={mapData.format_version || ''}
                    class="w-full rounded-md border border-border bg-input px-3 py-2 text-foreground focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/50"
                  />
                </div>

                <div>
                  <label class="block text-sm font-medium mb-2">脚本类型</label>
                  <select
                    name="script"
                    class="w-full rounded-md border border-border bg-input px-3 py-2 text-foreground focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/50"
                  >
                    <option value="0" selected={mapData.script === 0}>JASS</option>
                    <option value="1" selected={mapData.script === 1}>Lua</option>
                  </select>
                </div>

                <div>
                  <label class="block text-sm font-medium mb-2">玩家数量</label>
                  <input
                    type="number"
                    name="player_count"
                    value={mapData.player_count || 1}
                    class="w-full rounded-md border border-border bg-input px-3 py-2 text-foreground focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/50"
                  />
                </div>

                <div>
                  <label class="block text-sm font-medium mb-2">地形</label>
                  <input
                    type="text"
                    name="tileset"
                    value={mapData.tileset || ''}
                    class="w-full rounded-md border border-border bg-input px-3 py-2 text-foreground focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/50"
                  />
                </div>

                <div>
                  <label class="block text-sm font-medium mb-2">宽度</label>
                  <input
                    type="number"
                    name="width"
                    value={mapData.width || 0}
                    class="w-full rounded-md border border-border bg-input px-3 py-2 text-foreground focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/50"
                  />
                </div>

                <div>
                  <label class="block text-sm font-medium mb-2">高度</label>
                  <input
                    type="number"
                    name="height"
                    value={mapData.height || 0}
                    class="w-full rounded-md border border-border bg-input px-3 py-2 text-foreground focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/50"
                  />
                </div>

                <div>
                  <label class="block text-sm font-medium mb-2">可玩宽度</label>
                  <input
                    type="number"
                    name="playable_width"
                    value={mapData.playable_width || 0}
                    class="w-full rounded-md border border-border bg-input px-3 py-2 text-foreground focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/50"
                  />
                </div>

                <div>
                  <label class="block text-sm font-medium mb-2">可玩高度</label>
                  <input
                    type="number"
                    name="playable_height"
                    value={mapData.playable_height || 0}
                    class="w-full rounded-md border border-border bg-input px-3 py-2 text-foreground focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/50"
                  />
                </div>

                <div>
                  <label class="block text-sm font-medium mb-2">图形</label>
                  <select
                    name="graphics"
                    class="w-full rounded-md border border-border bg-input px-3 py-2 text-foreground focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/50"
                  >
                    <option value="0" selected={mapData.graphics === 0}>SD & HD</option>
                    <option value="1" selected={mapData.graphics === 1}>SD</option>
                    <option value="2" selected={mapData.graphics === 2}>HD</option>
                  </select>
                </div>

                <div>
                  <label class="block text-sm font-medium mb-2">队伍数量</label>
                  <input
                    type="number"
                    name="team_count"
                    value={mapData.team_count || 1}
                    class="w-full rounded-md border border-border bg-input px-3 py-2 text-foreground focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/50"
                  />
                </div>

               

                <div class="flex items-center gap-4">
                  <label class="flex items-center gap-2">
                    <input
                      type="checkbox"
                      name="has_triggers"
                      checked={mapData.has_triggers ? true : false}
                      class="h-4 w-4 rounded border-border text-primary focus:ring-primary"
                    />
                    <span class="text-sm">有触发器</span>
                  </label>

                  <label class="flex items-center gap-2">
                    <input
                      type="checkbox"
                      name="cheats"
                      checked={mapData.cheats ? true : false}
                      class="h-4 w-4 rounded border-border text-primary focus:ring-primary"
                    />
                    <span class="text-sm">允许作弊</span>
                  </label>

                  <label class="flex items-center gap-2">
                    <input
                      type="checkbox"
                      name="parsed"
                      checked={mapData.parsed ? true : false}
                      class="h-4 w-4 rounded border-border text-primary focus:ring-primary"
                    />
                    <span class="text-sm">已解析</span>
                  </label>
                </div>
              </div>

              <div class="flex justify-end gap-4">
                <button
                  type="button"
                  id="cancel-btn"
                  class="px-6 py-2 border border-border rounded-md hover:bg-muted transition-colors"
                >
                  取消
                </button>
                <button
                  type="submit"
                  class="px-6 py-2 bg-primary text-primary-foreground rounded-md hover:bg-primary/90 transition-colors"
                >
                  保存
                </button>
              </div>
            </form>
          </div>
        </div>
      </div>

      <script hoist>
        const editBtn = document.getElementById("edit-map-btn");
        const lang = editBtn?.dataset.lang || "zh";
        const modal = document.getElementById("edit-modal");
        const closeBtn = document.getElementById("close-modal-btn");
        const backdrop = document.getElementById("modal-backdrop");
        const cancelBtn = document.getElementById("cancel-btn");
        const form = document.getElementById("edit-map-form");

        // 打开模态框
        if (editBtn) {
          editBtn.addEventListener("click", () => {
            if (modal) modal.classList.remove("hidden");
          });
        }

        // 关闭模态框
        const closeModal = () => {
          if (modal) modal.classList.add("hidden");
        };

        if (closeBtn) closeBtn.addEventListener("click", closeModal);
        if (backdrop) backdrop.addEventListener("click", closeModal);
        if (cancelBtn) cancelBtn.addEventListener("click", closeModal);

        // 提交表单
        if (form) {
          form.addEventListener("submit", async (e) => {
            e.preventDefault();
            
            const formData = new FormData(form);
            
            try {
              const response = await fetch(`/${lang}/api/update-map`, {
                method: "POST",
                body: formData
              });
              
              const result = await response.json();
              
              if (result.success) {
                alert("更新成功！");
                closeModal();
                window.location.reload();
              } else {
                alert("更新失败：" + (result.error || "未知错误"));
              }
            } catch (error) {
              console.error("Error updating map:", error);
              alert("更新失败，请重试");
            }
          });
        }

        // ESC 键关闭模态框
        document.addEventListener("keydown", (e) => {
          if (e.key === "Escape" && modal && !modal.classList.contains("hidden")) {
            closeModal();
          }
        });
      </script>
    </>
  )}
</BaseLayout>
