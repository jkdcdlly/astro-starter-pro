---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { siteConfig } from '../../../config/site';
import { useTranslations, getLangFromUrl, ui, defaultLang } from "@/i18n";
import { dbService } from '../../../services/database';

const db = (Astro.locals as any).runtime.env.DB;

// Export getStaticPaths function
export function getStaticPaths() {
  const languages = Object.keys(ui).filter(lang => lang !== defaultLang);
  return languages.map(lang => ({
    params: { lang, author: 'author' },
    props: { lang },
  }));
}

interface Props {
  lang?: string;
}
const props = Astro.props;
const params = Astro.params;
const authorName = decodeURIComponent(params.author || '');

const lang = props.lang || getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// 尝试获取缓存
const cacheKey = new URL(Astro.request.url);
let cache: Cache | null = null;

try {
  if (typeof caches !== 'undefined') {
    cache = await caches.open('astro-cache');
  }
} catch (e) {
  console.log('Cache not available');
}

// 查询作者的所有地图和统计数据
let authorMaps: any[] = [];
let authorStats: any = {
  totalDownloads: 0,
  totalMaps: 0,
  totalPlayers: 0,
  totalHosted: 0,
  mostDownloadedMap: null
};

// 检查缓存中是否有数据
let cachedData: any = null;
if (cache) {
  try {
    const cachedResponse = await cache.match(cacheKey);
    if (cachedResponse) {
      cachedData = await cachedResponse.json();
      authorMaps = cachedData.authorMaps;
      authorStats = cachedData.authorStats;
    }
  } catch (e) {
    console.log('Cache read failed, fetching fresh data');
  }
}

// 如果缓存中没有数据或缓存不可用，从数据库获取
if (!cachedData) {
  try {
    // 获取作者的所有地图
    const mapsSql = 'SELECT * FROM wc3_maps_complete WHERE author = ? ORDER BY downloads DESC';
    authorMaps = await dbService.execute<any>(db, mapsSql, [authorName]);

    // 计算统计数据
    if (authorMaps.length > 0) {
      authorStats.totalMaps = authorMaps.length;
      authorStats.totalDownloads = authorMaps.reduce((sum, map) => sum + (map.downloads || 0), 0);
      authorStats.totalPlayers = authorMaps.reduce((sum, map) => sum + (map.users || 0), 0);
      authorStats.totalHosted = authorMaps.reduce((sum, map) => sum + (map.hosted_total || 0), 0);
      authorStats.mostDownloadedMap = authorMaps[0];
    }

    // 缓存结果（如果缓存可用）
    if (cache) {
      try {
        const response = new Response(JSON.stringify({ authorMaps, authorStats }), {
          headers: {
            'Cache-Control': 'public, max-age=300, s-maxage=300',
          }
        });
        await cache.put(cacheKey, response);
      } catch (e) {
        console.log('Cache write failed');
      }
    }
  } catch (error) {
    console.error('Error fetching author data:', error);
  }
}

// 设置响应头缓存
Astro.response.headers.set('Cache-Control', 'public, max-age=300, s-maxage=300');

// 如果没有找到作者数据，返回404
if (authorMaps.length === 0) {
  return Astro.redirect('/404');
}
---

<BaseLayout title={`${authorName} - Author Profile`} lang={lang}>
  <section class="py-12">
    <div class="container mx-auto px-4">
      <!-- Header -->
      <div class="text-center mb-12">
        <h1 class="text-3xl font-bold mb-4">{authorName}</h1>
        <p class="text-muted-foreground">Author Profile</p>
      </div>

      <!-- Stats Cards -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
        <div class="bg-card border border-border rounded-lg p-6 text-center">
          <div class="text-4xl font-bold text-primary mb-2">{authorStats.totalMaps}</div>
          <div class="text-muted-foreground">Total Maps</div>
        </div>
        <div class="bg-card border border-border rounded-lg p-6 text-center">
          <div class="text-4xl font-bold text-primary mb-2">{authorStats.totalDownloads.toLocaleString()}</div>
          <div class="text-muted-foreground">Total Downloads</div>
        </div>
        <div class="bg-card border border-border rounded-lg p-6 text-center">
          <div class="text-4xl font-bold text-primary mb-2">{authorStats.totalPlayers.toLocaleString()}</div>
          <div class="text-muted-foreground">Total Players</div>
        </div>
        <div class="bg-card border border-border rounded-lg p-6 text-center">
          <div class="text-4xl font-bold text-primary mb-2">{authorStats.totalHosted.toLocaleString()}</div>
          <div class="text-muted-foreground">Total Hosted</div>
        </div>
      </div>

      <!-- Author Bio (placeholder) -->
      <div class="bg-card border border-border rounded-lg p-6 mb-12">
        <h3 class="font-semibold text-lg mb-4">About {authorName}</h3>
        <p class="text-muted-foreground">Author biography coming soon...</p>
      </div>

      <!-- Most Popular Map -->
      {authorStats.mostDownloadedMap && (
        <div class="bg-card border border-border rounded-lg p-6 mb-12">
          <h3 class="font-semibold text-lg mb-4">Most Popular Map</h3>
          <a 
            href={props.lang ? `/map/${authorStats.mostDownloadedMap.id}/${authorStats.mostDownloadedMap.name2.toLowerCase().replace(/\s+/g, '-')}` : `/${lang}/map/${authorStats.mostDownloadedMap.id}/${authorStats.mostDownloadedMap.name2.toLowerCase().replace(/\s+/g, '-')}`}
            class="flex flex-col sm:flex-row gap-6 p-4 bg-muted/50 rounded-lg hover:bg-muted transition-colors"
          >
            <img 
              src={`https://wc3maps.com/static/maps/${authorStats.mostDownloadedMap.id}/archive/war3mapMap.jpg`} 
              alt={authorStats.mostDownloadedMap.name2}
              class="w-full sm:w-64 h-40 object-cover rounded-md"
              onerror="this.src='https://via.placeholder.com/256x160?text=No+Preview';"
            />
            <div class="flex-1">
              <h4 class="font-semibold text-xl mb-2">{authorStats.mostDownloadedMap.name2}</h4>
              <div class="grid grid-cols-2 gap-4 text-sm text-muted-foreground">
                <div>Downloads: <span class="font-medium text-foreground">{authorStats.mostDownloadedMap.downloads}</span></div>
                <div>Players: <span class="font-medium text-foreground">{authorStats.mostDownloadedMap.users}</span></div>
                <div>Hosted: <span class="font-medium text-foreground">{authorStats.mostDownloadedMap.hosted_total}</span></div>
                <div>Size: <span class="font-medium text-foreground">{authorStats.mostDownloadedMap.size ? `${(authorStats.mostDownloadedMap.size / 1024 / 1024).toFixed(2)} MB` : 'Unknown'}</span></div>
              </div>
            </div>
          </a>
        </div>
      )}

      <!-- All Maps by Author -->
      <div class="bg-card border border-border rounded-lg p-6">
        <h3 class="font-semibold text-lg mb-6">All Maps by {authorName}</h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
          {authorMaps.map((map) => (
            <div key={map.id} class="bg-muted/30 border border-border rounded-lg overflow-hidden hover:shadow-md transition-shadow">
              <a href={props.lang ? `/map/${map.id}/${map.name2.toLowerCase().replace(/\s+/g, '-')}` : `/${lang}/map/${map.id}/${map.name2.toLowerCase().replace(/\s+/g, '-')}`}>
                <div class="h-40 overflow-hidden">
                  <img 
                    src={`https://wc3maps.com/static/maps/${map.id}/archive/war3mapMap.jpg`} 
                    alt={map.name2}
                    class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
                    onerror="this.src='https://via.placeholder.com/400x225?text=No+Preview';"
                  />
                </div>
                <div class="p-4">
                  <h4 class="font-medium mb-1 truncate">{map.name2}</h4>
                  <div class="flex justify-between text-xs text-muted-foreground">
                    <span>Players: {map.users || 0}</span>
                    <span>Downloads: {map.downloads || 0}</span>
                  </div>
                </div>
              </a>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
