---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { siteConfig } from '../../config/site';
import { useTranslations, getLangFromUrl, ui, defaultLang } from "@/i18n";
// Export getStaticPaths function
export function getStaticPaths() {
  // Filter out default language (handled by root pages)
  const languages = Object.keys(ui).filter(lang => lang !== defaultLang);
  
  return languages.map(lang => ({
    params: { lang },
    props: { lang },
  }));
}
interface Props {
  params: {
    lang: string;
  };
}

const url = new URL(Astro.request.url);
console.log("Astro.request.url:", url);
const page = url.searchParams.get("page") ?? "1";
console.log("url.searchParams:", page);
const { params } = Astro.props;
// console.log('Astro searchParams :', Astro.searchParams);
const lang = getLangFromUrl(Astro.url);
// 从URL获取筛选参数
// const page = parseInt((Astro.url?.searchParams?.get('page') || '1'));
// console.log('Astro.request.url :', Astro.request.url);
console.log('Current URL searchParams:', Astro.url?.searchParams);
console.log('Current Page:', page);
const author = Astro.url?.searchParams?.get('author');
const users = Astro.url?.searchParams?.get('users');
const flags = Astro.url?.searchParams?.get('flags');

// 数据库连接配置
const DATABASE_URL = 'https://war3mapsn8n-jkdcdlly-gmail.aws-ap-northeast-1.turso.io/v2/pipeline';
const TOKEN = 'eyJhbGciOiJFZERTQSIsInR5cCI6IkpXVCJ9.eyJhIjoicnciLCJpYXQiOjE3NzIyMTcwMzUsImlkIjoiMDE5Y2EwNWQtMTIwMS03Y2I1LWJmY2YtNjM4OWUyNGVhOWYyIiwicmlkIjoiMGU3NTZmNjUtMzRlNC00NTU0LThhNjAtMDY3ZTA5MzBjMjViIn0.wktVX2ih_Us8qPJBvd1M7IGXe-ih5G5kUGLMWYxIAJPKQv8jtYs3C5Jmno-b0otorksooFX_ikd9XJkcWk_MDA';

// 构建查询条件
let whereClause = '';
const args = [];

if (author) {
  whereClause += whereClause ? ' AND ' : ' WHERE ';
  whereClause += 'author = ?';
  args.push({ type: 'text', value: author });
}

if (users) {
  whereClause += whereClause ? ' AND ' : ' WHERE ';
  whereClause += 'users >= ?';
  args.push({ type: 'integer', value: users.toString() });
}

if (flags) {
  whereClause += whereClause ? ' AND ' : ' WHERE ';
  whereClause += 'flags = ?';
  args.push({ type: 'integer', value: flags.toString() });
}

// 计算分页
const limit = 32;
const offset = (page - 1) * limit;

// 查询总记录数
let totalCount = 0;
try {
  const countSql = `SELECT COUNT(*) as count FROM wc3maps_map_list${whereClause};`;
//   console.log('Count SQL:', countSql);
//   console.log('Count Args:', args);
  
  const countResponse = await fetch(DATABASE_URL, {
    method: 'POST',
    headers: {
      'Authorization': `Bearer ${TOKEN}`,
      'Content-Type': 'application/json'
    },
    body: JSON.stringify({
      requests: [{
        type: 'execute',
        stmt: {
          sql: countSql,
          args: args
        }
      }]
    })
  });
//   console.log(`SELECT COUNT(*) as count FROM wc3maps_map_list ${whereClause};`)
  const countData = await countResponse.json();
//   console.log('Count Response:', countData);
//   console.log('Count Response - Results:', countData?.results);
//   console.log('Count Response - First Result:', countData?.results?.[0]);
//   console.log('Count Response - Response:', countData?.results?.[0]?.response);
//   console.log('Count Response - Rows:', countData?.results?.[0]?.response?.result?.rows);
//   console.log('Maps Response - Rows:', data?.results?.[0]?.response?.result?.rows);
//   maps = data?.results?.[0]?.response?.result?.rows || [];

  
  // 解析Turso返回的数组格式数据
  const countRows = countData?.results?.[0]?.response?.result?.rows || [];
  totalCount = countRows[0]?.[0]?.value || 0;
  console.log('Total Count:', totalCount);
} catch (error) {
  console.error('Error fetching count:', error);
}

// 查询地图数据
let maps = [];
try {
  const mapsSql = `SELECT id, name, author, users, flags, downloads, hosted_total FROM wc3maps_map_list${whereClause} ORDER BY id DESC LIMIT ? OFFSET ?;`;
  const mapsArgs = [...args, { type: 'integer', value: limit.toString() }, { type: 'integer', value: offset.toString() }];
//   console.log('Maps SQL:', mapsSql);
//   console.log('Maps Args:', mapsArgs);
  
  const response = await fetch(DATABASE_URL, {
    method: 'POST',
    headers: {
      'Authorization': `Bearer ${TOKEN}`,
      'Content-Type': 'application/json'
    },
    body: JSON.stringify({
      requests: [{
        type: 'execute',
        stmt: {
          sql: mapsSql,
          args: mapsArgs
        }
      }]
    })
  });

  const data = await response.json();
//   console.log('Maps Response:', data);
//   console.log('Maps Response - Results:', data?.results);
//   console.log('Maps Response - First Result:', data?.results?.[0]);
//   console.log('Maps Response - Response:', data?.results?.[0]?.response);
//   console.log('Maps Response - Rows:', data?.results?.[0]?.response?.result?.rows);
  
  // 解析Turso返回的数组格式数据
  const rows = data?.results?.[0]?.response?.result?.rows || [];
  maps = rows.map((row: any[]) => ({
    id: row[0]?.value,
    name: row[1]?.value,
    author: row[2]?.value,
    users: row[3]?.value,
    flags: row[4]?.value,
    downloads: row[5]?.value,
    hosted_total: row[6]?.value
  }));
  
//   console.log('Maps Data:', maps);
  console.log('Maps Count:', maps.length);
} catch (error) {
  console.error('Error fetching maps:', error);
}

// 计算总页数
const totalPages = Math.ceil(totalCount / limit);

// 生成分页链接
const generatePageUrl = (pageNum: number) => {
  const newUrl = new URL(Astro.url.toString());
  newUrl.searchParams.set('page', pageNum.toString());
//   console.log('Generated URL for page', pageNum, ':', newUrl.toString());
  return newUrl.pathname + newUrl.search;
};

// 获取所有作者列表（用于筛选）
let authors = [];
try {
  const authorsResponse = await fetch(DATABASE_URL, {
    method: 'POST',
    headers: {
      'Authorization': `Bearer ${TOKEN}`,
      'Content-Type': 'application/json'
    },
    body: JSON.stringify({
      requests: [{
        type: 'execute',
        stmt: {
          sql: 'SELECT DISTINCT author FROM wc3maps_map_list WHERE author IS NOT NULL AND author != \'\' ORDER BY author LIMIT 50;',
          args: []
        }
      }]
    })
  });

  const authorsData = await authorsResponse.json();
//   console.log('Authors Response:', authorsData);
  
  // 解析Turso返回的数组格式数据
  const authorRows = authorsData?.results?.[0]?.response?.rows || [];
  authors = authorRows.map((row: any[]) => row[0]?.value).filter(Boolean) || [];
  
  console.log('Authors Data:', authors);
  console.log('Authors Count:', authors.length);
} catch (error) {
  console.error('Error fetching authors:', error);
}
---

<BaseLayout title="Browse Maps" lang={lang}>
  <section class="py-12">
    <div class="container mx-auto px-4">
      <!-- Header -->
      <div class="text-center mb-12">
        <h1 class="text-3xl font-bold mb-4">Browse Maps</h1>
        <p class="text-muted-foreground">Discover custom Warcraft III maps and find your next adventure.</p>
      </div>

      <!-- Main Content -->
      <div class="flex flex-col lg:flex-row gap-8">
        <!-- Filters -->
        <div class="w-full lg:w-64 shrink-0">
          <div class="bg-card border border-border rounded-lg p-4">
            <h3 class="font-semibold mb-4">Filters</h3>
            
            <!-- Author Filter -->
            <div class="mb-6">
              <label class="block text-sm font-medium mb-2">Author</label>
              <select 
                class="w-full px-3 py-2 border border-border rounded-md bg-background" 
                onchange="window.location.href = this.value"
              >
                <option value="?page=1">All Authors</option>
                {authors.map((authorName: string) => (
                  <option 
                    key={authorName} 
                    value={`?page=1&author=${encodeURIComponent(authorName)}`}
                    selected={author === authorName}
                  >
                    {authorName}
                  </option>
                ))}
              </select>
            </div>

            <!-- Users Filter -->
            <div class="mb-6">
              <label class="block text-sm font-medium mb-2">Minimum Users</label>
              <select 
                class="w-full px-3 py-2 border border-border rounded-md bg-background" 
                onchange="window.location.href = this.value"
              >
                <option value="?page=1">All</option>
                <option value="?page=1&users=100" selected={users === '100'}>100+</option>
                <option value="?page=1&users=500" selected={users === '500'}>500+</option>
                <option value="?page=1&users=1000" selected={users === '1000'}>1000+</option>
                <option value="?page=1&users=5000" selected={users === '5000'}>5000+</option>
              </select>
            </div>

            <!-- Flags Filter -->
            <div class="mb-6">
              <label class="block text-sm font-medium mb-2">Flags</label>
              <select 
                class="w-full px-3 py-2 border border-border rounded-md bg-background" 
                onchange="window.location.href = this.value"
              >
                <option value="?page=1">All</option>
                <option value="?page=1&flags=0" selected={flags === '0'}>None</option>
                <option value="?page=1&flags=1" selected={flags === '1'}>Flag 1</option>
                <option value="?page=1&flags=2" selected={flags === '2'}>Flag 2</option>
                <option value="?page=1&flags=3" selected={flags === '3'}>Flag 3</option>
              </select>
            </div>
          </div>
        </div>

        <!-- Map Grid -->
        <div class="flex-1">
          <!-- Results Info -->
          <div class="flex justify-between items-center mb-6">
            <div class="text-sm text-muted-foreground">
              Showing {offset + 1}-{Math.min(offset + limit, totalCount)} of {totalCount} maps
            </div>
            <div class="flex items-center">
              <span class="text-sm mr-2">Sort by:</span>
              <select class="px-3 py-1 border border-border rounded-md bg-background text-sm">
                <option>Most Recent</option>
                <option>Most Popular</option>
                <option>Most Downloaded</option>
              </select>
            </div>
          </div>

          <!-- Maps Grid -->
          <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
            {maps.map((map: any) => (
              <div key={map.id} class="bg-card border border-border rounded-lg overflow-hidden hover:shadow-md transition-shadow">
                <!-- Map Preview -->
                <div class="h-48 overflow-hidden">
                  <img 
                    src={`https://wc3maps.com/static/maps/${map.id}/archive/war3mapMap.jpg`} 
                    alt={map.name} 
                    class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
                    loading="lazy"
                    onerror="this.src='https://via.placeholder.com/400x225?text=No+Preview';"
                  />
                </div>
                <!-- Map Info -->
                <div class="p-4">
                  <h3 class="font-medium mb-1 truncate">{map.name}</h3>
                  <p class="text-sm text-muted-foreground mb-3">by {map.author || 'Unknown'}</p>
                  <div class="flex justify-between text-xs text-muted-foreground">
                    <span>Players: {map.users}</span>
                    <span>Downloads: {map.downloads}</span>
                  </div>
                </div>
              </div>
            ))}
          </div>

          <!-- Pagination -->
          {totalPages > 1 && (
            <div class="flex justify-center mt-12">
              <div class="flex items-center space-x-2">
                {page > 1 && (
                  <a 
                    href={generatePageUrl(page - 1)} 
                    class="px-4 py-2 border border-border rounded-md hover:bg-muted transition-colors"
                  >
                    Previous
                  </a>
                )}
                
                {Array.from({ length: Math.min(5, totalPages) }, (_, i) => {
                  let pageNum = i + 1;
                  if (totalPages > 5) {
                    if (page > 3) {
                      pageNum = Math.min(page - 2 + i, totalPages);
                    }
                  }
                  return (
                    <a 
                      key={pageNum} 
                      href={generatePageUrl(pageNum)} 
                      class={`px-4 py-2 border border-border rounded-md ${pageNum == page ? 'bg-primary text-primary-foreground' : 'hover:bg-muted'} transition-colors`}
                    >
                      {pageNum}
                    </a>
                  );
                })}
                
                {page < totalPages && (
                  <a 
                    href={generatePageUrl(page + 1)} 
                    class="px-4 py-2 border border-border rounded-md hover:bg-muted transition-colors"
                  >
                    Next
                  </a>
                )}
              </div>
            </div>
          )}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>