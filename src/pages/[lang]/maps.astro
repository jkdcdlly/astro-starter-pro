---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { siteConfig } from '../../config/site';
import { useTranslations, getLangFromUrl, ui, defaultLang } from "@/i18n";
import { dbService } from '@/services/database';
const db = Astro.locals.runtime.env.DB;
interface Props {
  params: {
    lang: string;
  };
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// 从URL获取筛选参数
const url = new URL(Astro.request.url);
const page: number = parseInt(url.searchParams.get("page") || "1");
const author = Astro.url?.searchParams?.get('author');
const users = Astro.url?.searchParams?.get('users');
const flags = Astro.url?.searchParams?.get('flags');
const search = Astro.url?.searchParams?.get('search');

// 构建查询条件
let whereClause = ' WHERE group_id > 0 and length(tags)>0 ';
const args: (string | number)[] = [];

if (search) {
  whereClause += ' AND name LIKE ?';
  args.push(`%${search}%`);
}

if (author) {
  whereClause += ' AND author = ?';
  args.push(author);
}

if (users) {
  whereClause += ' AND users >= ?';
  args.push(parseInt(users));
}

if (flags) {
  whereClause += ' AND flags = ?';
  args.push(parseInt(flags));
}

// 计算分页
const limit = 12;
const offset = (page - 1) * limit;

// 初始化数据变量
let totalCount = 0;
let maps: any[] = [];

// 尝试获取缓存
const cacheKey = new Request(url.toString());
let cache: Cache | null = null;

try {
  if (typeof caches !== 'undefined') {
    cache = await caches.open('astro-cache');
  }
} catch (e) {
  console.log('Cache not available');
}

// 检查缓存中是否有数据
if (cache) {
      try {
        const cachedResponse = await cache.match(cacheKey);
        if (cachedResponse) {
          const cachedData: any = await cachedResponse.json();
          totalCount = cachedData.totalCount;
          maps = cachedData.maps;
          console.log('Loaded from cache');
        }
      } catch (e) {
        console.log('Cache read failed, fetching fresh data');
      }
    }

// 如果缓存中没有数据或缓存不可用，从数据库获取
if (!maps.length) {
  try {
    // 查询总数
    totalCount = await dbService.getCount(db,'wc3_maps_complete', whereClause, args);

    // 查询地图数据
    const mapsSql = `SELECT id, name2 as name, author, users, flags, downloads, hosted_total FROM wc3_maps_complete ${whereClause} ORDER BY id DESC LIMIT ? OFFSET ?`;
    const mapsArgs = [...args, limit, offset];
    const mapsResult = await dbService.execute<any>(db,mapsSql, mapsArgs);
    maps = mapsResult || [];

    // 缓存结果（如果缓存可用）
    if (cache) {
      try {
        const cacheData = { totalCount, maps };
        const response = new Response(JSON.stringify(cacheData), {
          headers: {
            'Cache-Control': 'public, max-age=300, s-maxage=300',
          }
        });
        await cache.put(cacheKey, response);
      } catch (e) {
        console.log('Cache write failed');
      }
    }
  } catch (error) {
    console.error('Error fetching data:', error);
  }
}

// 如果还是没有数据，提供调试信息
if (maps.length === 0) {
  console.log('No maps found at the end - db available:', !!db);
  console.log('=== END DEBUG ===');
}

// 设置响应头缓存
Astro.response.headers.set('Cache-Control', 'public, max-age=300, s-maxage=300');

// 计算总页数
const totalPages = Math.ceil(totalCount / limit);

// 生成分页链接
const generatePageUrl = (pageNum: number) => {
  const newUrl = new URL(Astro.url.toString());
  newUrl.searchParams.set('page', pageNum.toString());
  return newUrl.pathname + newUrl.search;
};



---

<BaseLayout title="Browse Maps" lang={lang}>
  <section class="py-12">
    <div class="container mx-auto px-4">
      <!-- Header -->
      <div class="text-center mb-12">
        <h1 class="text-3xl font-bold mb-4">{t('BrowseMaps')}</h1>
        <p class="text-muted-foreground">Discover custom Warcraft III maps and find your next adventure.</p>
      </div>

      <!-- Main Content -->
      <div class="flex flex-col lg:flex-row gap-8">
        <!-- Filters -->
        <div class="w-full lg:w-64 shrink-0">
          <div class="bg-card border border-border rounded-lg p-4">
            <h3 class="font-semibold mb-4">Filters</h3>
            
            <!-- Author Filter -->
            <div class="mb-6 relative">
              <label class="block text-sm font-medium mb-2">Author</label>
              <input
                type="text"
                id="author-input"
                placeholder="Search author..."
                value={author || ''}
                class="w-full px-3 py-2 border border-border rounded-md bg-background"
                autocomplete="off"
              />
              <div 
                id="author-suggestions" 
                class="absolute z-10 w-full mt-1 bg-background border border-border rounded-md shadow-lg hidden"
              ></div>
            </div>

            <script>
              const authorInput = document.getElementById('author-input');
              const suggestionsDiv = document.getElementById('author-suggestions');
              let debounceTimer;

              authorInput?.addEventListener('input', function(e) {
                clearTimeout(debounceTimer);
                const query = e.target.value.trim();

                if (!query) {
                  suggestionsDiv.classList.add('hidden');
                  return;
                }

                debounceTimer = setTimeout(async () => {
                  try {
                    const response = await fetch(`/api/authors?q=${encodeURIComponent(query)}`);
                    const authors = await response.json();

                    if (authors.length > 0) {
                      suggestionsDiv.innerHTML = authors.map(author => `
                        <div 
                          class="px-3 py-2 cursor-pointer hover:bg-muted first:rounded-t-md last:rounded-b-md"
                          data-author="${author}"
                        >
                          ${author}
                        </div>
                      `).join('');
                      suggestionsDiv.classList.remove('hidden');

                      document.querySelectorAll('#author-suggestions div').forEach(item => {
                        item.addEventListener('click', function() {
                          const selectedAuthor = this.getAttribute('data-author');
                          window.location.href = `?page=1&author=${encodeURIComponent(selectedAuthor)}`;
                        });
                      });
                    } else {
                      suggestionsDiv.classList.add('hidden');
                    }
                  } catch (error) {
                    console.error('Error fetching authors:', error);
                  }
                }, 300);
              });

              document.addEventListener('click', function(e) {
                if (!authorInput?.contains(e.target) && !suggestionsDiv.contains(e.target)) {
                  suggestionsDiv.classList.add('hidden');
                }
              });
            </script>

            <!-- Users Filter -->
            <div class="mb-6">
              <label class="block text-sm font-medium mb-2">Minimum Users</label>
              <select 
                class="w-full px-3 py-2 border border-border rounded-md bg-background" 
                onchange="window.location.href = this.value"
              >
                <option value="?page=1">All</option>
                <option value="?page=1&users=100" selected={users === '100'}>100+</option>
                <option value="?page=1&users=500" selected={users === '500'}>500+</option>
                <option value="?page=1&users=1000" selected={users === '1000'}>1000+</option>
                <option value="?page=1&users=5000" selected={users === '5000'}>5000+</option>
              </select>
            </div>

            <!-- Flags Filter -->
            <div class="mb-6">
              <label class="block text-sm font-medium mb-2">Flags</label>
              <select 
                class="w-full px-3 py-2 border border-border rounded-md bg-background" 
                onchange="window.location.href = this.value"
              >
                <option value="?page=1">All</option>
                <option value="?page=1&flags=0" selected={flags === '0'}>None</option>
                <option value="?page=1&flags=1" selected={flags === '1'}>Flag 1</option>
                <option value="?page=1&flags=2" selected={flags === '2'}>Flag 2</option>
                <option value="?page=1&flags=3" selected={flags === '3'}>Flag 3</option>
              </select>
            </div>
          </div>
        </div>

        <!-- Map Grid -->
        <div class="flex-1">
          <!-- Results Info -->
          <div class="flex justify-between items-center mb-6">
            <div class="text-sm text-muted-foreground">
              Showing {offset + 1}-{Math.min(offset + limit, totalCount)} of {totalCount} maps
            </div>
            <div class="flex items-center">
              <span class="text-sm mr-2">Sort by:</span>
              <select class="px-3 py-1 border border-border rounded-md bg-background text-sm">
                <option>Most Recent</option>
                <option>Most Popular</option>
                <option>Most Downloaded</option>
              </select>
            </div>
          </div>

          <!-- Maps Grid -->
          <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
            {maps.map((map: any) => (
              <div key={map.id} class="bg-card border border-border rounded-lg overflow-hidden hover:shadow-md transition-shadow">
                <a href={`/map/${map.id}/${map.name}`}>
                <!-- Map Preview -->
                <div class="h-48 overflow-hidden">
                  <img 
                    src={`https://wc3maps.com/static/maps/${map.id}/archive/war3mapMap.jpg`} 
                    alt={map.name} 
                    class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
                    fetchpriority="high" 
                    onerror="this.src='https://via.placeholder.com/400x225?text=No+Preview';"
                  />
                </div>
                <!-- Map Info -->
                <div class="p-4">
                  <h3 class="font-medium mb-1 truncate">{map.name}</h3>
                  <p class="text-sm text-muted-foreground mb-3">by {map.author ? (
                    <a href={`/${lang}/author/${encodeURIComponent(map.author)}`} class="text-primary hover:underline" onclick="event.stopPropagation()">
                      {map.author}
                    </a>
                  ) : 'Unknown'}</p>
                  <div class="flex justify-between text-xs text-muted-foreground">
                    <span>Players: {map.users}</span>
                    <span>Downloads: {map.downloads}</span>
                  </div>
                </div>
                </a>
              </div>
            ))}
          </div>

          <!-- Pagination -->
          {totalPages > 1 && (
            <div class="flex justify-center mt-12">
              <div class="flex items-center space-x-2">
                <!-- Previous Page Button -->
                {page > 1 && (
                  <a 
                    href={generatePageUrl(page - 1)} 
                    class="px-4 py-2 border border-border rounded-md hover:bg-muted transition-colors"
                  >
                    Previous
                  </a>
                )}
                <!-- Page Numbers -->
                {(() => {
                  const pages = [];
                  const maxPages = Math.min(5, totalPages);
                  let start = 1;
                  
                  if (totalPages > 5) {
                    if (page > 3 && page < totalPages - 2) {
                      start = page - 2;
                    } else if (page >= totalPages - 2) {
                      start = totalPages - 4;
                    }
                  }
                  
                  for (let i = 0; i < maxPages; i++) {
                    const pageNum = start + i;
                    pages.push(
                      <a 
                        key={pageNum} 
                        href={generatePageUrl(pageNum)} 
                        class={`px-4 py-2 border border-border rounded-md ${pageNum == page ? 'bg-primary text-primary-foreground' : 'hover:bg-muted'} transition-colors`}
                      >
                        {pageNum}
                      </a>
                    );
                  }
                  
                  return pages;
                })()}
                <!-- Next Page Button -->
                {page < totalPages && (
                  <a 
                    href={generatePageUrl(page + 1)} 
                    class="px-4 py-2 border border-border rounded-md hover:bg-muted transition-colors"
                  >
                    Next
                  </a>
                )}
              </div>
            </div>
          )}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
