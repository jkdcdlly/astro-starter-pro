---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { siteConfig } from "@/config/site";
import Hero from "@/components/widgets/Hero.astro";
import Features from "@/components/widgets/Features.astro";
import FeatureVote from "@/components/widgets/FeatureVote.astro";
import Content from "@/components/widgets/Content.astro";
import ServiceList from "@/components/widgets/ServiceList.astro";
import { useTranslations, getLangFromUrl, ui, defaultLang } from "@/i18n";
import { dbService } from '@/services/database';

let db: any = null;
try {
  if ((Astro.locals as any)?.runtime?.env?.DB) {
    db = (Astro.locals as any).runtime.env.DB;
  }
} catch (e) {
  console.log('DB not available in this context');
}

// 推荐的地图 ID 数组 - 在这里添加或修改推荐地图
const featuredMapIds = [2706,1088,1307,739,4081,58];


// Export getStaticPaths function
export function getStaticPaths() {
  const languages = Object.keys(ui).filter(lang => lang !== defaultLang);
  return languages.map(lang => ({
    params: { lang },
    props: { lang },
  }));
}

// Get current language from URL
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const metadata = {
    title: `${siteConfig.name} — A Home for War3 Players and Creators — Warcraft 3 Maps`,
    description:
        "A modern and professional template for your web projects with Astro and Tailwind CSS. Boost your development with a solid foundation.",
    ignoreTitleTemplate: true,
};

// 查询推荐地图数据
let featuredMaps: any[] = [];
if (db && featuredMapIds.length > 0) {
  try {
    const placeholders = featuredMapIds.map(() => '?').join(',');
    const sql = `SELECT * FROM wc3_maps_complete WHERE id IN (${placeholders})`;
    const maps = await dbService.execute<any>(db, sql, featuredMapIds);
    
    // 按照指定的 ID 顺序排序
    featuredMaps = featuredMapIds
      .map(id => maps.find(m => m.id === id))
      .filter(Boolean);
  } catch (error) {
    console.error('Error fetching featured maps:', error);
  }
}

const services = [
    {
        title: t('services.webDevelopment.title'),
        description: t('services.webDevelopment.description'),
        icon: "lucide:globe",
    },
    {
        title: t('services.seo.title'),
        description: t('services.seo.description'),
        icon: "lucide:search",
    },
    {
        title: t('services.consulting.title'),
        description: t('services.consulting.description'),
        icon: "lucide:rocket",
    },
];
---

<BaseLayout metadata={metadata} lang={lang}>
  <!-- Search Bar -->
    <section class="py-12 bg-muted/50">
        <div class="container mx-auto px-4">
            <div class="max-w-3xl mx-auto">
                <form action={`/${lang}/maps`} method="GET" class="relative">
                    <input
                        type="text"
                        name="search"
                        placeholder={t('search.placeholder')}
                        class="w-full px-6 py-4 pr-12 rounded-full border border-border bg-background shadow-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent"
                    />
                    <button
                        type="submit"
                        class="absolute right-2 top-1/2 transform -translate-y-1/2 px-4 py-2 rounded-full bg-primary text-white font-medium transition-colors hover:bg-primary/90"
                    >
                        {t('search.button')}
                    </button>
                </form>
            </div>
        </div>
    </section>
    <Hero
        title={`${t('hero.title')}`}
        tagline={t('hero.tagline')}
        description={t('hero.description')}
        actions={[
            {
                text: t('hero.getStarted'),
                href: "https://github.com/devgelo-labs/astro-starter-pro",
                variant: "primary",
                icon: "lucide:github",
            },
            {
                text: t('hero.ourServices'),
                href: `/${lang}/services`,
                variant: "secondary",
                icon: "lucide:arrow-right",
                ariaLabel: "Learn more about our services",
            },
        ]}
    >
         <Features
        tagline={t('features.tagline')}
        title={t('features.title')}
        subtitle={t('features.subtitle')}
        features={[
            {
                title: t('features.optimizedSeo'),
                description:
                    t('features.optimizedSeoDesc'),
                icon: "lucide:scan-search",
                iconClass: "bg-blue-500/10 text-blue-400",
            },
            {
                title: t('features.highPerformance'),
                description: t('features.highPerformanceDesc'),
                icon: "lucide:zap",
                iconClass: "bg-purple-500/10 text-purple-400",
            },
            {
                title: t('features.tailwind'),
                description:
                    t('features.tailwindDesc'),
                icon: "lucide:palette",
                iconClass: "bg-pink-500/10 text-pink-400",
            },
        ]}
    />
    </Hero>

    <Content
        tagline={t('index.mapRecommendation')}
        title={t('index.featuredMaps')}
        classes={{ container: "pb-0 md:pb-0" }}
    />
   
    <!-- Featured Maps Section -->
    {featuredMaps.length > 0 && (
        <section class="py-12">
            <div class="container mx-auto px-4">
                <div class="text-center mb-12">
                    <h2 class="text-3xl font-bold mb-4">{t('index.featuredMaps')}</h2>
                    <p class="text-muted-foreground">
                        {lang === 'zh' ? '精选 Warcraft 3 地图推荐' : 'Featured Warcraft 3 Maps'}
                    </p>
                </div>
                
                <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
                    {featuredMaps.map((map) => (
                        <div key={map.id} class="bg-card border border-border rounded-lg overflow-hidden hover:shadow-md transition-shadow">
                            <a href={`/${lang}/map/${map.id}/${map.name2.toLowerCase().replace(/\s+/g, '-')}`}>
                                <div class="h-40 overflow-hidden">
                                    <img 
                                        src={`https://wc3maps.com/static/maps/${map.id}/archive/war3mapMap.jpg`} 
                                        alt={map.name2}
                                        class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
                                        onerror="this.src='https://via.placeholder.com/400x225?text=No+Preview';"
                                    />
                                </div>
                                <div class="p-4">
                                    <h3 class="font-medium mb-1 truncate">{map.name2}</h3>
                                    <p class="text-sm text-muted-foreground mb-2">
                                        by {map.author || 'Unknown'}
                                    </p>
                                    <div class="flex justify-between text-xs text-muted-foreground">
                                        <span>Players: {map.users || 0}</span>
                                        <span>Downloads: {map.downloads || 0}</span>
                                    </div>
                                </div>
                            </a>
                        </div>
                    ))}
                </div>
            </div>
        </section>
    )}

    <!-- Feature Vote Section -->
    <FeatureVote lang={lang} />
</BaseLayout>